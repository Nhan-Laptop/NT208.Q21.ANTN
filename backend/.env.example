# AIRA Backend Environment Example
# Copy to backend/.env for local development. Do not commit real secrets.

# ---------------------------------------------------------------------------
# App runtime
# ---------------------------------------------------------------------------
APP_NAME="AIRA Backend"
APP_ENV=development
API_V1_STR=/api/v1
DEBUG=false

# ---------------------------------------------------------------------------
# Database / migrations
# ---------------------------------------------------------------------------
# Local default is SQLite. Use a PostgreSQL URL for staging/production.
# Production safety validation rejects SQLite when APP_ENV=production.
DATABASE_URL=sqlite:///./aira.db

# Optional migration-only DB URL. If unset, Alembic uses DATABASE_URL unless
# alembic.ini explicitly provides sqlalchemy.url.
ALEMBIC_DATABASE_URL=

# ---------------------------------------------------------------------------
# Academic crawl + RAG runtime
# ---------------------------------------------------------------------------
# Persistent Chroma path, resolved relative to backend/ by the current service.
CHROMA_DB_PATH=data/chroma_db

# Offline fixture seed path. Production crawl does not include this source by default.
ACADEMIC_SEED_PATH=data/academic_seed.json

# Live academic source registry.
ACADEMIC_LIVE_SOURCES_PATH=crawler/sources.json
ACADEMIC_LIVE_CRAWL_ENABLED=true
CRAWLER_USER_AGENT=AIRA-ScholarlyCrawler/1.0 contact:admin@aira.local
CRAWLER_RATE_LIMIT_SECONDS=2
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_MAX_RETRIES=3
CRAWLER_RAW_STORAGE_PATH=data/raw_snapshots
CLARIVATE_MANUAL_IMPORT_DIR=data/imports/clarivate
CLARIVATE_USERNAME=
CLARIVATE_PASSWORD=
USE_BROWSER_CRAWLER=false
BROWSER_HEADLESS=true

# Optional explicit Chromium/Chrome runtime for live crawl validation.
# Use repo-local paths for dev/staging if a system browser is unavailable.
ACADEMIC_BROWSER_PATH=
ACADEMIC_BROWSER_LIBRARY_PATH=

# Hugging Face/model cache root, resolved relative to backend/ by the embedding service.
HF_CACHE_DIR=.cache/huggingface
HF_TOKEN=

# SPECTER2 embedding configuration.
SPECTER2_MODEL_NAME=allenai/specter2
SPECTER2_FALLBACK_MODEL_NAME=allenai/specter2_base
SPECTER2_MAX_CHARS=12000

# ---------------------------------------------------------------------------
# AI Writing Detection
# ---------------------------------------------------------------------------
# Pre-download the RoBERTa model before using the feature to avoid
# long download delays during API requests:
#
#     cd backend && source .venv/bin/activate
#     python scripts/download_detector_model.py
#
AI_DETECT_ML_ENABLED=true
AI_DETECT_MODEL_NAME=roberta-base-openai-detector
AI_DETECT_ALLOW_DOWNLOAD=true
AI_DETECT_ENSEMBLE_WEIGHT_ML=0.7
AI_DETECT_ENSEMBLE_WEIGHT_RULES=0.3
AI_DETECT_USE_SPECTER2=false

# Local/demo fallback only. Set false in staging/production to fail loudly when
# real SPECTER2 weights cannot be loaded.
# Runtime validation rejects true when APP_ENV=staging or APP_ENV=production.
ACADEMIC_EMBEDDING_HASH_FALLBACK=true

# Startup behavior. For local development, prefer running Alembic explicitly:
#   cd backend && .venv/bin/alembic upgrade head
# Keep startup schema creation disabled so local DBs remain Alembic-versioned.
# Runtime validation rejects startup schema creation in staging/production.
ACADEMIC_ENABLE_STARTUP_SCHEMA_CREATE=false
ACADEMIC_ENABLE_STARTUP_SOURCE_BOOTSTRAP=false
ACADEMIC_ENABLE_STARTUP_CHROMA_INIT=false

# Live crawl records robots/HTTP failures and never fabricates academic records.

# ---------------------------------------------------------------------------
# Auth / admin bootstrap
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=replace-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

ADMIN_EMAIL=admin@aira.local
ADMIN_PASSWORD=ChangeMe!123

# AES-GCM master key. Prefer ADMIN_MASTER_KEY_B64 in deployed environments.
ADMIN_MASTER_KEY_B64=
MASTER_KEY_FILE=.aira_master_key

# ---------------------------------------------------------------------------
# LLM providers
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=
GROQ_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GROQ_MODEL=llama-3.1-8b-instant
CHAT_CONTEXT_WINDOW=8
SYSTEM_PROMPT="Bạn là AIRA — trợ lý nghiên cứu học thuật chuyên nghiệp. Luôn gọi công cụ (function call) khi cần dữ liệu học thuật thực tế. Không bao giờ bịa DOI, trích dẫn, hay số liệu. Trả lời ngắn gọn, chính xác, mang tính học thuật."

# ---------------------------------------------------------------------------
# Storage / upload
# ---------------------------------------------------------------------------
# local: force filesystem storage for local development.
# auto: use S3 when all S3 settings are present, otherwise local.
# s3: require S3 and fail startup if it cannot initialize.
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=local_storage
LOCAL_STORAGE_CLEANUP_DAYS=90

AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

MAX_UPLOAD_SIZE_MB=20
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/gif,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ---------------------------------------------------------------------------
# CORS / security headers / rate limits
# ---------------------------------------------------------------------------
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept

SECURITY_HEADERS_ENABLED=true
CSP_POLICY="default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https:;"
TRANSPORT_ENCRYPTION_ENABLED=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_CHAT_MAX=60
RATE_LIMIT_TOOLS_MAX=40
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_DEFAULT_MAX=120

# ---------------------------------------------------------------------------
# Observability / health
# ---------------------------------------------------------------------------
AUDIT_LOG_FILE=audit.log
HEALTH_INCLUDE_DETAILS=false
